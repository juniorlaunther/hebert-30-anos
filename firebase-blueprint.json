{
  "entities": {
    "Guest": {
      "title": "Guest",
      "description": "A guest invited to the birthday party.",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the guest."
        },
        "confirmed": {
          "type": "boolean",
          "description": "Whether the guest has confirmed attendance."
        },
        "confirmedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the guest confirmed attendance."
        },
        "companions": {
          "type": "number",
          "description": "Number of companions the guest is bringing."
        },
        "message": {
          "type": "string",
          "description": "A message for the birthday person."
        }
      },
      "required": ["name", "confirmed"]
    }
  },
  "firestore": {
    "/guests/{guestId}": {
      "schema": "Guest",
      "description": "Collection of guests."
    }
  }
}
